ALLOWED_USER_IDS=123456789

# === Security ===
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# === Wallet / Trading ===
PRIVATE_KEY=
FEE_WALLET_PUBLIC_KEY=
FEE_WALLET_PRIVATE_KEY=
