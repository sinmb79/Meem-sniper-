TAKE_PROFIT_1_SELL_PCT=50
TAKE_PROFIT_2_PCT=300
TAKE_PROFIT_2_SELL_PCT=100
STOP_LOSS_PCT=30
TIME_LIMIT_MINUTES=10
MAX_POSITIONS=5

# === Safety Filters ===
